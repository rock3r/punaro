# Use only for local development: go run ./cmd/punarod --env-file .env
# Production should use a secret manager, protected service credentials, Docker
# secrets, Kubernetes secrets, or another environment-injection mechanism.
PUNARO_LISTEN_ADDR=127.0.0.1:8080
# Reserved for the future stateful relay; unused by the health-only daemon.
PUNARO_DATA_DIR=./data
# Validated but not applied to the current standard logger.
PUNARO_LOG_LEVEL=info
# PUNARO_TELEGRAM_BOT_TOKEN=
# PUNARO_CLOUDFLARE_ACCESS_AUD=
# PUNARO_MACHINE_KEY_PATH=
# Attachments are disabled by default. Setting this to true intentionally makes
# the current daemon exit: attachment v2 has not passed its release gates.
# These future values must be injected from a protected service secret, never
# committed.
# PUNARO_ATTACHMENTS_ENABLED=false
# PUNARO_ATTACHMENT_DEVICE_KEYS_JSON={"device-id":"base64raw-ed25519-public-key"}
# PUNARO_ATTACHMENT_MEMBERSHIP_JSON=[{"sender":"sender-device","conversation":"conversation-id","recipient":"recipient-device","actions":["create","upload","download","signal"]}]
