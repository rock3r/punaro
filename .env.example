# Use only for local development: go run ./cmd/punarod --env-file .env
# Production should use a secret manager, protected service credentials, Docker
# secrets, Kubernetes secrets, or another environment-injection mechanism.
PUNARO_LISTEN_ADDR=127.0.0.1:8080
# SQLite relay state when PUNARO_RELAY_ENABLED=true and the default relay store
# is selected.
PUNARO_DATA_DIR=./data
# Validated but not applied to the current standard logger.
PUNARO_LOG_LEVEL=info
# PUNARO_TELEGRAM_BOT_TOKEN=
# Cloudflare Access requires issuer, audience, and exactly one JWKS source.
# For a systemd deployment, use the root-managed local snapshot populated by
# deploy/systemd/punaro-jwks-refresh.service; do not open daemon egress.
# PUNARO_ACCESS_ISSUER=https://team.cloudflareaccess.example
# PUNARO_ACCESS_AUDIENCE=
# PUNARO_ACCESS_JWKS_FILE=/etc/punaro/jwks/current.json
# PUNARO_ACCESS_JWKS_URL=https://team.cloudflareaccess.example/cdn-cgi/access/certs
# PUNARO_MACHINE_KEY_PATH=
# PostgreSQL is an additive, dark platform substrate in the current slice.
# Ordinary punarod startup is read-only and requires an already compatible
# schema. Put the application DSN in an absolute 0600 file; never put it here.
# PUNARO_POSTGRES_ENABLED=false
# PUNARO_POSTGRES_DSN_FILE=/run/secrets/punaro-postgres-app-dsn
# Dark native memory read API. Requires PostgreSQL device authentication and
# the validated ingress policy; mutation and client surfaces remain separate.
# PUNARO_MEMORY_API_ENABLED=false
# Explicit test/qualification selector. `postgres` requires the compatible
# schema above and does not import or dual-write the existing SQLite relay.
# PUNARO_RELAY_STORE=sqlite
# Legacy attachment v2/v3, directory, and permit variables are retired. Their
# presence, including an empty value or `false`, makes punarod fail startup.
# Use only the trusted-relay surface and native client documented below.
# PUNARO_TRUSTED_ATTACHMENTS_ENABLED=false
# PUNARO_TRUSTED_ATTACHMENT_BLOB_DIR=/absolute/private/punaro/blobs
